# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in. The .env file is .gitignored and NOT uploaded on
# deploy — on Vercel, add the same vars in Project → Settings → Environment
# Variables (Production + Preview).
# ─────────────────────────────────────────────────────────────────────────────

# ── Required at runtime ──────────────────────────────────────────────────────

# MongoDB connection used by the production repository adapter.
# Tests do not need this — they use the in-memory repository fake.
# Local: mongodb://localhost:27017  |  Atlas: mongodb+srv://...
MONGODB_URI=mongodb://localhost:27017

# Database name. Optional — defaults to "maraflamini" if unset.
MONGODB_DB=maraflamini

# Auth.js (NextAuth v5) — secret that signs the session JWT. REQUIRED in prod.
# Generate one with: npx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET=replace-me-with-a-random-secret

# On Vercel the request host is trusted automatically — AUTH_TRUST_HOST and
# AUTH_URL are NOT needed. Set AUTH_URL only behind a custom proxy/domain:
# AUTH_URL=https://your-domain.com

# ── Seeding the single Professional (one-off: scripts/seed-professional.mjs) ──
# Only the seed script reads these; the running app does not.
SEED_PROFESSIONAL_EMAIL=mara@example.com
SEED_PROFESSIONAL_PASSWORD=change-me

# ── Not yet wired — no code reads these today ────────────────────────────────
# Placeholders for the future email / WhatsApp notification work. Notifications
# use a Fake sender right now (ADR-0001 — WhatsApp via Baileys, deferred).
GOOGLE_EMAIL=
GOOGLE_APP_NAME=
GOOGLE_APP_PASSWORD=
WHATSAPP_NUMBER=
