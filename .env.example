# MongoDB connection used by the production repository adapter.
# Tests do not need this — they use the in-memory repository fake.
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<password>@<cluster-host>/?retryWrites=true&w=majority&appName=<app>
#         (URL-encode the password if it contains reserved characters)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=maraflamini

# Auth.js (NextAuth) — secret used to sign the session JWT.
# Generate one with: npx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET=replace-me-with-a-random-secret

# Credentials for seeding the single Professional (used by scripts/seed-professional.mjs).
SEED_PROFESSIONAL_EMAIL=mara@example.com
SEED_PROFESSIONAL_PASSWORD=change-me

# Public origin used to build the cancel link in Notifications (.../cita/<id>).
# Must be the real deployment URL in production — not localhost — or the cancel
# links in real WhatsApp/email messages won't resolve.
PUBLIC_BASE_URL=http://localhost:3000

# Email Channel — nodemailer over Gmail (ADR-0003). Used by the Notification
# worker (scripts/notification-worker.ts). If GMAIL_USER/GMAIL_APP_PASSWORD are
# unset, the worker logs a warning and uses the fake email sender instead.
# GMAIL_APP_PASSWORD is a 16-char Google App Password (requires 2-Step
# Verification on the account) — NOT the account password. Gmail caps a standard
# account at ~500 messages/day, well above clinic volume.
GMAIL_USER=clinic@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# From header: optional display name + address. Defaults to GMAIL_USER if unset.
MAIL_FROM=Mara Flamini <clinic@gmail.com>

# How often the Notification worker drains the outbox, in milliseconds (default 5000).
NOTIFICATION_WORKER_INTERVAL_MS=5000
