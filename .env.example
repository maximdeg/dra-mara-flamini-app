# MongoDB connection used by the production repository adapter.
# Tests do not need this — they use the in-memory repository fake.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=maraflamini

# Auth.js (NextAuth) — secret used to sign the session JWT.
# Generate one with: npx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET=replace-me-with-a-random-secret

# Credentials for seeding the single Professional (used by scripts/seed-professional.mjs).
SEED_PROFESSIONAL_EMAIL=mara@example.com
SEED_PROFESSIONAL_PASSWORD=change-me
