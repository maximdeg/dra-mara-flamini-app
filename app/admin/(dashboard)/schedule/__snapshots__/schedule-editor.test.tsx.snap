exports[`ScheduleEditor > matches the editor structure 1`] = `"<div><div><div><label><input type="checkbox" checked=""><span>Lunes</span></label><div><div><input lang="es-AR" aria-label="Desde" type="time" value="09:00"><span>a</span><input lang="es-AR" aria-label="Hasta" type="time" value="13:00"><button type="button">Quitar</button></div><button type="button">Agregar rango</button></div></div><div><label><input type="checkbox"><span>Martes</span></label><p>No se atiende.</p></div><div><label><input type="checkbox"><span>Miércoles</span></label><p>No se atiende.</p></div><div><label><input type="checkbox"><span>Jueves</span></label><p>No se atiende.</p></div><div><label><input type="checkbox"><span>Viernes</span></label><p>No se atiende.</p></div><div><label><input type="checkbox"><span>Sábado</span></label><p>No se atiende.</p></div><div><label><input type="checkbox"><span>Domingo</span></label><p>No se atiende.</p></div></div><button type="button">Guardar horarios</button></div>"`;
