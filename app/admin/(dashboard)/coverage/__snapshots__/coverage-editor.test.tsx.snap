// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`CoverageEditor > matches the editor structure 1`] = `"<div><div><h2>Particular (Self-Pay)</h2><p>Las dos variantes Particular son fijas: no se pueden renombrar ni eliminar, solo se editan sus precios.</p><form><div><label><span>Particular (Consulta) — precio</span><input min="0" type="number" value="30000" name="consultationFullPrice"></label></div><div><label><span>Practica Particular — precio (también es la seña)</span><input min="0" type="number" value="35000" name="practiceFullPrice"></label></div><div><label><span>Seña de primera consulta Particular</span><input min="0" type="number" value="20000" name="firstVisitConsultationDeposit"></label></div><button type="submit">Guardar precios</button></form></div><div><h2>Obras sociales</h2><ul><li><form><div><label><span>Nombre<span aria-hidden="true"> *</span></span><input required="" value="OSDE" name="name"></label></div><div><label><span>Precio</span><input min="0" type="number" value="5000" name="price"></label></div><div><label><span>Notas</span><input value="Bono" name="notes"></label></div><div><button type="submit">Guardar</button><button type="button">Quitar</button></div></form></li></ul><div><h3>Agregar obra social</h3><form><div><label><span>Nombre<span aria-hidden="true"> *</span></span><input required="" name="name"></label></div><div><label><span>Precio</span><input min="0" type="number" value="0" name="price"></label></div><div><label><span>Notas</span><input name="notes"></label></div><button type="submit">Agregar</button></form></div></div></div>"`;
