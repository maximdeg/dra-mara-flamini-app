// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AgendarVisitaPage > matches the booking form structure 1`] = `"<form><div><h2>Tus datos</h2><div><div><label><span>Nombre<span aria-hidden="true"> *</span></span><input required="" name="patientFirstName"></label></div><div><label><span>Apellido<span aria-hidden="true"> *</span></span><input required="" name="patientLastName"></label></div><div><label><span>Teléfono<span aria-hidden="true"> *</span></span><input required="" name="patientPhone"></label></div><div><label><span>Email<span aria-hidden="true"> *</span></span><input required="" type="email" name="patientEmail"></label></div></div></div><div><h2>Tu visita</h2><div><div><label><span>Tipo de visita<span aria-hidden="true"> *</span></span><select required=""><option value="">Elegí…</option><option value="Consultation">Consulta</option><option value="Practice">Práctica</option></select></label></div><div><label><span>Cobertura<span aria-hidden="true"> *</span></span><select required="" disabled=""><option value="">Elegí un tipo de visita primero</option></select></label></div></div></div><div><h2>Fecha y hora</h2><div><div><label><span>Fecha<span aria-hidden="true"> *</span></span><select required=""><option value="">Elegí una fecha…</option><option value="2026-06-22">22/06/2026</option><option value="2026-06-23">23/06/2026</option></select></label></div><div><label><span>Hora<span aria-hidden="true"> *</span></span><select required="" disabled=""><option value="">Elegí una fecha primero</option></select></label></div></div></div><div><button type="submit" disabled="">Agendar</button></div></form>"`;
